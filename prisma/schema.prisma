// University Management System - Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                  @id @default(autoincrement())
  email              String               @unique
  password           String
  name               String?
  roleId             Int
  role               Role                 @relation(fields: [roleId], references: [id], onDelete: Restrict)
  isActive           Boolean              @default(true)
  attendanceSessions AttendanceSession[]
  tuitionPayments    TuitionPayment[]
  bankWithdrawals    BankWithdrawal[]
  bankTransfers      BankTransfer[]
  transactionHistory TransactionHistory[]
  expensesRequested  Expense[]            @relation("ExpenseRequestedBy")
  expensesApproved   Expense[]            @relation("ExpenseApprovedBy")
  payrollsRequested  Payroll[]            @relation("PayrollRequestedBy")
  payrollsApproved   Payroll[]            @relation("PayrollApprovedBy")
  monthlyInvoicesCreated StudentMonthlyInvoice[]
  monthlyFeePaymentsRecorded StudentMonthlyPayment[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@map("users")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique // e.g. "users.view", "users.create"
  description String?
  module      String? // e.g. "users", "admission", "attendance"
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Faculty {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  code        String       @unique // e.g. "ENG", "SCI", "BUS"
  description String?
  program     String? // "Bachelor", "Masters"
  isActive    Boolean      @default(true)
  departments Department[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("faculties")
}

model Lecturer {
  id             Int                  @id @default(autoincrement())
  name           String
  email          String               @unique
  phone          String?
  degree         String?
  imageUrl       String? // Cloudinary URL
  imagePublicId  String?
  cvUrl          String? // Cloudinary URL for CV PDF
  cvPublicId     String?
  isActive       Boolean              @default(true)
  departments    LecturerDepartment[]
  courses        LecturerCourse[]
  classSchedules ClassSchedule[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@map("lecturers")
}

model LecturerDepartment {
  lecturerId   Int
  departmentId Int
  lecturer     Lecturer   @relation(fields: [lecturerId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([lecturerId, departmentId])
  @@map("lecturer_departments")
}

model LecturerCourse {
  lecturerId Int
  courseId   Int
  lecturer   Lecturer @relation(fields: [lecturerId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([lecturerId, courseId])
  @@map("lecturer_courses")
}

model Department {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  code        String               @unique // e.g. "CS", "EE", "ACC"
  description String?
  facultyId   Int
  faculty     Faculty              @relation(fields: [facultyId], references: [id], onDelete: Restrict)
  tuitionFee  Float?               @default(0)
  isActive    Boolean              @default(true)
  courses     Course[]
  classes     Class[]
  students    Student[]
  lecturers   LecturerDepartment[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("departments")
}

model Course {
  id             Int                 @id @default(autoincrement())
  name           String
  code           String              // e.g. "CS101", "ENG201" - unique per department
  description    String?
  creditHours    Int                 @default(3)
  departmentId   Int
  department     Department          @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  isActive       Boolean             @default(true)
  assessments    CourseAssessment[]
  examRecords    ExamRecord[]
  lecturers      LecturerCourse[]
  classSchedules ClassSchedule[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([code, departmentId])
  @@unique([name, departmentId])
  @@map("courses")
}

/// Per-course grading components; weightPercent values should sum to 100. Max marks for each = weightPercent (out of 100 total).
model CourseAssessment {
  id            Int     @id @default(autoincrement())
  courseId      Int
  course        Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name          String // e.g. "Mid Exam", "Assignment"
  key           String // stable id for JSON scores & import columns, e.g. "midExam"
  weightPercent Float
  sortOrder     Int     @default(0)

  @@unique([courseId, key])
  @@index([courseId])
  @@map("course_assessments")
}

model Semester {
  id        Int      @id @default(autoincrement())
  name      String   @unique // e.g. "Fall", "Spring", "Summer"
  sortOrder Int      @default(0) // for display/ordering (lower = earlier in year)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("semesters")
}

model AcademicYear {
  id        Int      @id @default(autoincrement())
  startYear Int      // e.g. 2024
  endYear   Int      // e.g. 2025
  name      String   @unique // e.g. "2024-2025"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  students  Student[]

  @@map("academic_years")
}

model Class {
  id                 Int                 @id @default(autoincrement())
  name               String // e.g. "Level 1-A", "Section B"
  departmentId       Int
  department         Department          @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  semester           String // e.g. "Fall", "Spring", "Summer"
  year               Int // e.g. 2026 (from academic year)
  room               String? // e.g. "Room 201"
  schedule           String? // e.g. "Mon/Wed 9:00-10:30"
  capacity           Int                 @default(40)
  isActive           Boolean             @default(true)
  attendanceSessions AttendanceSession[]
  students           Student[]
  classSchedules     ClassSchedule[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([name, semester, year])
  @@map("classes")
}

model ClassSchedule {
  id         Int      @id @default(autoincrement())
  classId    Int
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  courseId   Int
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Restrict)
  lecturerId Int
  lecturer   Lecturer @relation(fields: [lecturerId], references: [id], onDelete: Restrict)
  dayOfWeek  String // "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"
  shift      String // "Morning", "Afternoon", "Evening"
  startTime  String // e.g. "09:00"
  endTime    String // e.g. "10:30"
  semester   String
  year       Int
  room       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([classId, dayOfWeek, shift, startTime])
  @@map("class_schedules")
}

model Student {
  id                 Int                  @id @default(autoincrement())
  studentId          String               @unique // e.g. "STD-2026-0001"
  firstName          String
  lastName           String
  motherName         String?
  parentPhone        String?
  email              String?              @unique
  phone              String?
  dateOfBirth        DateTime?
  gender             String? // "Male", "Female"
  address            String?
  imageUrl           String? // Cloudinary URL (optional)
  imagePublicId      String? // Cloudinary public_id for deletion
  departmentId       Int
  department         Department           @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  admissionAcademicYearId Int?
  admissionAcademicYear   AcademicYear?   @relation(fields: [admissionAcademicYearId], references: [id], onDelete: SetNull)
  classId            Int?
  class              Class?               @relation(fields: [classId], references: [id], onDelete: SetNull)
  program            String? // "Bachelor", "Masters"
  admissionDate      DateTime             @default(now())
  status             String               @default("Admitted") // "Pending", "Admitted", "Rejected", "Graduated"
  paymentStatus      String               @default("Fully Paid") // "Full Scholarship", "Half Scholar", "Fully Paid"
  fee                Float?               // Monthly tuition amount for invoicing; if null, department tuitionFee is used
  balance            Float                @default(0) // Amount owed; charged at registration, reduced by payments
  monthlyInvoices    StudentMonthlyInvoice[]
  monthlyFeePayments StudentMonthlyPayment[]
  attendanceRecords  AttendanceRecord[]
  examRecords        ExamRecord[]
  tuitionPayments    TuitionPayment[]
  transactionHistory TransactionHistory[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@map("students")
}

model Bank {
  id                 Int                  @id @default(autoincrement())
  name               String // e.g. "Dahabshiil - Main", "Edahab - Tuition"
  code               String               @unique // e.g. "DHB-001", "EDH-001"
  accountNumber      String? // Bank account number
  balance            Float                @default(0)
  isActive           Boolean              @default(true)
  tuitionPayments    TuitionPayment[] // Payments deposited to this bank
  monthlyFeePayments StudentMonthlyPayment[]
  withdrawals        BankWithdrawal[]     @relation("WithdrawFromBank")
  transfersOut       BankTransfer[]       @relation("TransferFromBank")
  transfersIn        BankTransfer[]       @relation("TransferToBank")
  transactionHistory TransactionHistory[]
  expenses           Expense[]
  payrolls           Payroll[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@map("banks")
}

model TransactionHistory {
  id               Int      @id @default(autoincrement())
  type             String // "deposit" | "withdrawal" | "transfer_out" | "transfer_in"
  amount           Float
  bankId           Int
  bank             Bank     @relation(fields: [bankId], references: [id], onDelete: Restrict)
  relatedBankId    Int? // For transfers: the other bank
  description      String? // Human-readable e.g. "Tuition: John Doe - Fall 2026"
  studentId        Int?
  student          Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  tuitionPaymentId Int?
  studentMonthlyPaymentId Int? @unique
  linkedMonthlyFeePayment StudentMonthlyPayment? @relation("MonthlyFeeDeposit", fields: [studentMonthlyPaymentId], references: [id], onDelete: SetNull)
  bankWithdrawalId Int?
  bankTransferId   Int?
  createdAt        DateTime @default(now())
  createdById      Int?
  createdBy        User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@map("transaction_history")
}

model TuitionPayment {
  id            Int      @id @default(autoincrement())
  studentId     Int
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  bankId        Int? // Optional for legacy payments; required for new deposits
  bank          Bank?    @relation(fields: [bankId], references: [id], onDelete: SetNull)
  amount        Float    @default(0)
  semester      String // "Fall", "Spring", "Summer"
  year          Int // e.g. 2026
  paymentMethod String   @default("bank_receipt") // "bank_receipt" | "electronic" | "cash_on_hand"
  receiptNumber String? // Bank receipt number
  transactionId String? // Electronic transaction ID
  paymentDate   DateTime @default(now()) // Date student actually paid
  paidAt        DateTime @default(now()) // When recorded in system
  recordedById  Int?
  recordedBy    User?    @relation(fields: [recordedById], references: [id], onDelete: SetNull)
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([studentId, semester, year])
  @@map("tuition_payments")
}

// One row per student per calendar month when a monthly fee is posted to balance (prevents double charge).
model StudentMonthlyInvoice {
  id            Int      @id @default(autoincrement())
  studentId     Int
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  year          Int
  month         Int // 1–12
  amount        Float
  note          String?
  createdAt     DateTime @default(now())
  createdById   Int?
  createdBy     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([studentId, year, month])
  @@map("student_monthly_invoices")
}

// Monthly fee payments (calendar months); one row per month. batchId groups rows from the same receipt.
model StudentMonthlyPayment {
  id            Int      @id @default(autoincrement())
  batchId       String   @db.VarChar(36)
  studentId     Int
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  bankId        Int
  bank          Bank     @relation(fields: [bankId], references: [id], onDelete: Restrict)
  year          Int
  month         Int // 1–12
  amount        Float
  paymentMethod String   @default("bank_receipt")
  receiptNumber String?
  transactionId String?
  paymentDate   DateTime @default(now())
  paidAt        DateTime @default(now())
  recordedById  Int?
  recordedBy    User?    @relation(fields: [recordedById], references: [id], onDelete: SetNull)
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  depositTransaction TransactionHistory? @relation("MonthlyFeeDeposit")

  @@unique([studentId, year, month])
  @@index([batchId])
  @@map("student_monthly_payments")
}

model BankWithdrawal {
  id          Int      @id @default(autoincrement())
  bankId      Int
  bank        Bank     @relation("WithdrawFromBank", fields: [bankId], references: [id], onDelete: Restrict)
  amount      Float
  reason      String?
  withdrawnAt DateTime @default(now())
  createdById Int?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@map("bank_withdrawals")
}

model Expense {
  id              Int       @id @default(autoincrement())
  amount          Float
  description     String
  category        String? // e.g. "Operations", "Salaries", "Utilities"
  bankId          Int? // Bank to withdraw from when approved
  bank            Bank?     @relation(fields: [bankId], references: [id], onDelete: SetNull)
  status          String    @default("pending") // "pending" | "approved" | "rejected"
  requestedById   Int
  requestedBy     User      @relation("ExpenseRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  approvedById    Int?
  approvedBy      User?     @relation("ExpenseApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("expenses")
}

model BankTransfer {
  id            Int      @id @default(autoincrement())
  fromBankId    Int
  fromBank      Bank     @relation("TransferFromBank", fields: [fromBankId], references: [id], onDelete: Restrict)
  toBankId      Int
  toBank        Bank     @relation("TransferToBank", fields: [toBankId], references: [id], onDelete: Restrict)
  amount        Float
  reason        String?
  transferredAt DateTime @default(now())
  createdById   Int?
  createdBy     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@map("bank_transfers")
}

model AttendanceSession {
  id        Int                @id @default(autoincrement())
  classId   Int
  class     Class              @relation(fields: [classId], references: [id], onDelete: Restrict)
  date      DateTime           @db.Date
  shift     String // "Morning", "Afternoon", "Evening"
  takenById Int
  takenBy   User               @relation(fields: [takenById], references: [id], onDelete: Restrict)
  takenAt   DateTime           @default(now()) // exact timestamp when attendance was taken
  note      String?
  records   AttendanceRecord[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([classId, date, shift])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id        Int               @id @default(autoincrement())
  sessionId Int
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId Int
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status    String // "Present", "Absent", "Late", "Excused"
  note      String?
  createdAt DateTime          @default(now())

  @@unique([sessionId, studentId])
  @@map("attendance_records")
}

model Position {
  id          Int        @id @default(autoincrement())
  name        String     @unique // e.g. "Registrar", "Accountant", "HR Officer"
  description String?
  isActive    Boolean    @default(true)
  employees   Employee[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("positions")
}

model Employee {
  id         Int       @id @default(autoincrement())
  name       String
  email      String    @unique
  phone      String?
  positionId Int
  position   Position  @relation(fields: [positionId], references: [id], onDelete: Restrict)
  department String? // e.g. "Admin", "Finance", "IT Support"
  hireDate   DateTime  @default(now())
  isActive   Boolean   @default(true)
  payrolls   Payroll[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("employees")
}

model Payroll {
  id              Int       @id @default(autoincrement())
  amount          Float
  description     String
  period          String? // e.g. "January 2026", "Q1 2026"
  employeeId      Int? // Optional link to employee
  employee        Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  bankId          Int? // Bank to pay from when approved
  bank            Bank?     @relation(fields: [bankId], references: [id], onDelete: SetNull)
  status          String    @default("pending") // "pending" | "approved" | "rejected"
  requestedById   Int
  requestedBy     User      @relation("PayrollRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  approvedById    Int?
  approvedBy      User?     @relation("PayrollApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("payrolls")
}

model ExamRecord {
  id         Int      @id @default(autoincrement())
  studentId  Int
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId   Int
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Restrict)
  semester   String // "Fall", "Spring", "Summer"
  year       Int // e.g. 2026
  scores     Json     @default("{}") // { "midExam": 15, "finalExam": 32, ... } keys match CourseAssessment.key
  totalMarks Float    @default(0) // sum of component marks (out of 100)
  grade      String? // "A", "A-", "B+", "B", "B-", "C+", "C", "D", "F"
  gradePoints Float?  @default(0) // 4.0, 3.7, 3.3, 3.0, 2.7, 2.3, 2.0, 1.0, 0.0
  status     String   @default("approved") // "draft" | "approved" - draft until instructor verifies
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([studentId, courseId, semester, year])
  @@map("exam_records")
}
